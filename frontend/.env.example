# Copy to `.env.local` in this folder. Vite only exposes variables prefixed with VITE_.
#
# Optional: full backend origin (no trailing slash). If empty/unset, axios uses same-origin
# paths like `/api/...` and the Vite dev proxy (vite.config.js) forwards to the backend.
VITE_API_URL=
# Example when not using the proxy:
# VITE_API_URL=http://localhost:8000
